import java.util.*;
class Song{
    private String name;
    private String author;
    private int duration;

    public Song(String name, String author, int duration) {
        this.name = name;
        this.author = author;
        this.duration = duration;
    }

    public String getAuthor() {
        return author;
    }

    public String getName() {
        return name;
    }

    public double getDuration() {
        return duration;
    }
}
public class Main {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        int t = scanner.nextInt();
        scanner.nextLine();
        while (t-- > 0){
            String name1 = scanner.next();
            String author1 = scanner.next();
            int duration1 = scanner.nextInt();
            Song song1 = new Song(name1, author1, duration1);
            String name2 = scanner.next();
            String author2 = scanner.next();
            int duration2 = scanner.nextInt();
            Song song2 = new Song(name2, author2, duration2);
            if(song1.getName().equals(song2.getName()) && song1.getAuthor().equals(song2.getAuthor()) && song1.getDuration() == song2.getDuration()){
                System.out.println("true");
            }
            else{
                System.out.println("false");
            }
        }
    }
}
