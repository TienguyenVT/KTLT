Rút tiền thành công! Số dư còn lại: 3000.0
*/

import java.util.*;

class LoiKhongDuTien extends Exception {
    public LoiKhongDuTien(String thongBao) {
        super(thongBao);
    }
}

class TaiKhoanNganHang {
    private double soDu;

    public TaiKhoanNganHang(double soDu) {
        this.soDu = soDu;
    }

    public void rutTien(double soTienRut) throws LoiKhongDuTien {
        if (soTienRut < 0) {
            throw new IllegalArgumentException("Số tiền rút không được âm!");
        }

        if (soTienRut > soDu) {
            throw new LoiKhongDuTien("Số dư không đủ để rút " + soTienRut);
        }

        soDu -= soTienRut;
    }

    public double laySoDu() {
        return soDu;
    }
}

public class Main {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);

        int t = scanner.nextInt();
        scanner.nextLine();

        double soDuBanDau = Double.parseDouble(scanner.nextLine().trim());

        TaiKhoanNganHang taiKhoan = new TaiKhoanNganHang(soDuBanDau);

        while (scanner.hasNextLine()) {
            String dongNhap = scanner.nextLine().trim();

            if (dongNhap.isEmpty()) {
                continue;
            }

            try {
                double soTienRut = Double.parseDouble(dongNhap);

                taiKhoan.rutTien(soTienRut);

                System.out.println("Rút tiền thành công! Số dư còn lại: " + taiKhoan.laySoDu());
            } catch (NumberFormatException e) {
                System.out.println("Lỗi: Vui lòng nhập số hợp lệ!");
            } catch (IllegalArgumentException e) {
                System.out.println("Lỗi: " + e.getMessage());
            } catch (LoiKhongDuTien e) {
                System.out.println("Lỗi: " + e.getMessage());
            }
        }
    }
}
