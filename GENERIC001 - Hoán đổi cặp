import java.util.*;
class Pair<T>{
    private T first;
    private T second;
    public Pair (T first, T second){
        this.first = first;
        this.second = second;
    }
    public void swap(){
        T temp = this.first;
        this.first = this.second;
        this.second = temp;
    }
    public void display(){
        if(first instanceof String && !isNumeric((String) first)){
            System.out.println("'"+first+"' '"+second+"'");
        }else{
            System.out.println(first+" "+second);
        }
    }
    private boolean isNumeric(String str) {
        return str.matches("-?\\d+(\\.\\d+)?");
    }
}
public class Main {
    public static void main(String[] args){
        Scanner sc = new Scanner (System.in);
        int t = sc.nextInt();
        sc.nextLine();
        while(t-->0){
            String firstInput =sc.next();
            String secondInput = sc.next();
            Pair<String> pair = new Pair<>(firstInput,secondInput);
            pair.swap();
            pair.display();
        }
    }

}
